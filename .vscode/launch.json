{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug C (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tail2.exe",
            "args": ["-n", "100", "test.txt"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-debug"
        }
    ]
}